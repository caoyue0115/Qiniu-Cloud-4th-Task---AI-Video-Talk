# 阿里云百炼 DashScope API Key（必填）
# 申请地址：https://bardal.console.aliyun.com/ 或 https://dashscope.console.aliyun.com/apiKey
sk-（这一行完整的填）

# 可选：覆盖默认模型
# 视觉大模型（复杂场景）
VISION_MODEL_FULL=qwen-vl-max
# 视觉小模型（简单场景，更便宜）
VISION_MODEL_MINI=qwen-vl-plus
# 对话/文本模型
CHAT_MODEL=qwen-plus
# ASR 语音识别模型
ASR_MODEL=paraformer-realtime-v2
# TTS 语音合成模型
TTS_MODEL=cosyvoice-v1
TTS_VOICE=longxiaochun
